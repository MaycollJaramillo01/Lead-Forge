# ── Neon (Postgres) ───────────────────────────────────────────────
# pooled (pgbouncer) — used by the app at runtime
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/leadforge?sslmode=require"
# direct — used by Prisma migrations
DIRECT_URL="postgresql://USER:PASS@ep-xxx.us-east-2.aws.neon.tech/leadforge?sslmode=require"

# ── Auth (NextAuth v5 / Auth.js) ──────────────────────────────────
AUTH_SECRET=""                 # openssl rand -base64 32
ADMIN_EMAIL="info@cluster.marketing"
ADMIN_PASSWORD=""              # password for the single internal user

# ── Inngest ───────────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Discovery / audit (MVP, free) ─────────────────────────────────
OVERPASS_ENDPOINT="https://overpass-api.de/api/interpreter"
GEOAPIFY_API_KEY=""
PAGESPEED_API_KEY=""           # Google PageSpeed Insights (free)
CRUX_API_KEY=""                # Chrome UX Report (free)
CENSUS_API_KEY=""              # U.S. Census (free)

# ── Enrichment (hot leads only) ───────────────────────────────────
HUNTER_API_KEY="ac92c18d01a9c6376213b7c290a5ae6e0f00f867"

# ── Phase 2 (leave empty for MVP) ─────────────────────────────────
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
GOOGLE_PLACES_API_KEY=""
FOURSQUARE_API_KEY=""

# ── Export ────────────────────────────────────────────────────────
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=""   # base64
GOHIGHLEVEL_WEBHOOK_URL=""

# ── Cron protection ───────────────────────────────────────────────
CRON_SECRET=""

# ── Budget guard (free-tier daily caps, requests/day) ─────────────
BUDGET_PAGESPEED_DAILY="25000"
BUDGET_GEOAPIFY_DAILY="3000"
BUDGET_HUNTER_MONTHLY="25"
